# ===========================================================================
# Edge Function secrets — LOCAL DEVELOPMENT ONLY
# ---------------------------------------------------------------------------
# Copy this file to  supabase/functions/.env  (gitignored) and paste your real
# values. Then run the functions locally with:
#
#     supabase functions serve generate-content --env-file supabase/functions/.env
#
# For PRODUCTION, do NOT use this file — push the same secrets to Supabase:
#
#     supabase secrets set OPENAI_API_KEY=sk-your-real-key
#
# NOTE: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically by
# the Supabase platform in deployed functions, so you only need them here for
# fully-local serving (the CLI injects local ones automatically too).
# ===========================================================================

# >>> PASTE YOUR OPENAI KEY HERE WHEN READY <<<
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# Optional: override the model (defaults to gpt-4o-mini inside the function).
# OPENAI_MODEL=gpt-4o-mini
