# ===========================================================================
# Classyx — environment variables (template)
# Copy to ".env":   cp .env.example .env     (.env is gitignored)
# ===========================================================================
#
# There are TWO classes of variables. Read the headers carefully.
#
#   PUBLIC  (VITE_*) — safe to ship in the browser bundle. Go in .env.
#   SECRET           — must NEVER appear in the frontend, in .env, or in any
#                      VITE_* variable. They live ONLY in Supabase (server-side
#                      Edge Function secrets). They are listed here for
#                      documentation; see the "SECRET" section for where they
#                      actually go.
# ---------------------------------------------------------------------------


# ---------------------------------------------------------------------------
# PUBLIC — frontend (Vite). These ship in the browser. That is expected;
# your data is protected by Row Level Security, not by hiding these.
#   URL / anon key:  Supabase Dashboard -> Project Settings -> API
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key-here

# Cloudflare Turnstile (bot check on the landing-page waitlist). Public site key.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key


# ---------------------------------------------------------------------------
# SECRET — server-side ONLY. DO NOT put these in .env or any VITE_ variable.
# They are read by Supabase Edge Functions via Deno.env.get(...).
#
# Set them with the Supabase CLI (NOT in this repo):
#
#     supabase secrets set OPENAI_API_KEY=sk-your-real-key
#
# ...or for local `supabase functions serve`, put them in
# supabase/functions/.env (also gitignored — see supabase/functions/.env.example).
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically into
# every Edge Function by the platform — you do NOT set them yourself.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY   <-- you'll set this when ready
# OPENAI_MODEL=gpt-4o-mini                          (optional override)
